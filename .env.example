# ==============================================================================
# Development Environment Configuration Template
# Copy this file to '.env' and adjust the values as needed.
# ==============================================================================

# PHP Configuration
PHP_VERSION=8.3                # Options: 8.2, 8.3, 8.4
XDEBUG_MODE=debug,develop       # Modes: off, debug, coverage, profile, develop
TIMEZONE=America/Guayaquil      # Timezone for all containers (PHP, MariaDB, etc.)

# Ports (Local Host -> Container)
PORT_NGINX=8801                # Nginx HTTP port
PORT_NGINX_HTTPS=8811          # Nginx HTTPS port
PORT_APACHE=8802               # Apache HTTP port
PORT_APACHE_HTTPS=8812         # Apache HTTPS port
PORT_MARIADB=8803              # MariaDB database port
PORT_PHPMYADMIN=8804           # phpMyAdmin web interface
PORT_MAILPIT=8805              # Mailpit web UI port
PORT_MAILPIT_SMTP=8825         # Mailpit SMTP port (for PHP mail)

# Database Configuration
MARIADB_DATABASE=my_app_db     # Initial database name
MARIADB_USER=my_app_user       # Database user (non-root)

# Docker Project Namespace
COMPOSE_PROJECT_NAME=modern-xampp
