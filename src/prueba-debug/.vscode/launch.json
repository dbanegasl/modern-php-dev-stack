{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Listen for Xdebug (prueba-debug)",
      "type": "php",
      "request": "launch",
      "port": 9003,
      "pathMappings": {
        "/var/www/html/prueba-debug": "${workspaceFolder}"
      },
      "ignore": [
        "**/vendor/**/*.php"
      ]
    }
  ]
}
