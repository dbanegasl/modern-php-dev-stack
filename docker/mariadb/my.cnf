# ==============================================================================
# MariaDB Custom Configuration
# ==============================================================================
# This configuration ensures UTF-8 MB4 charset and proper collation

[mysqld]
# Timezone configuration
# Uses the system timezone from TZ environment variable
# For explicit timezone, use: default-time-zone='+00:00' or default-time-zone='America/Bogota'

# Character set and collation for all databases and tables
character-set-server=utf8mb4
collation-server=utf8mb4_unicode_ci

# Performance optimizations
max_connections=1000
max_allowed_packet=256M
default-storage-engine=InnoDB

[mysql]
# Ensure client connections also use UTF-8 MB4
default-character-set=utf8mb4

[mysqldump]
default-character-set=utf8mb4
